---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from './Icon.astro';
import { site } from '../config/site';

interface Props {
  titre: string;
  titreCourt: string;
  intro: string;
  travaux: string[];
  faq: { q: string; r: string }[];
  image?: string;
  imageAlt?: string;
  description?: string;
}

const { titre, titreCourt, intro, travaux, faq, image, imageAlt, description } = Astro.props;

const etapes = [
  { n: '1', titre: 'Échange & analyse du besoin', texte: 'Nous étudions votre projet, vos contraintes et votre budget.' },
  { n: '2', titre: 'Devis détaillé', texte: 'Vous recevez un chiffrage clair, poste par poste.' },
  { n: '3', titre: 'Réalisation', texte: 'Exécution des travaux avec un suivi régulier du chantier.' },
  { n: '4', titre: 'Réception', texte: 'Visite de réception et remise de l\'ouvrage.' },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.r,
    },
  })),
};
---

<BaseLayout
  title={`${titreCourt} | ${site.nomEntreprise}`}
  description={description ?? `${titre} ${site.zone}. ${site.nomEntreprise}, entreprise de ${site.metier}. Devis gratuit, équipe qualifiée.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  <section class="bg-anthracite-700 text-white py-12 sm:py-16">
    <div class="container-page">
      <nav class="text-sm text-anthracite-300 mb-4">
        <a href="/" class="hover:text-chantier-400">Accueil</a> ›
        <a href="/services" class="hover:text-chantier-400">Services</a> ›
        <span class="text-white">{titreCourt}</span>
      </nav>
      <h1 class="text-3xl sm:text-5xl font-display font-bold mb-3 text-white">{titre}</h1>
      <p class="text-lg text-anthracite-200 max-w-2xl">Intervention {site.zone}</p>
    </div>
  </section>

  <section class="section">
    <div class="container-page grid gap-10 lg:grid-cols-2 items-start">
      <div>
        <p class="text-lg leading-relaxed text-anthracite-600 mb-6">{intro}</p>
        <h2 class="text-xl font-semibold mb-4 text-anthracite-800">Travaux réalisés</h2>
        <ul class="space-y-2">
          {travaux.map((t) => (
            <li class="flex gap-3">
              <Icon name="check" class="w-5 h-5 shrink-0 text-chantier-500 mt-0.5" />
              <span class="text-anthracite-600">{t}</span>
            </li>
          ))}
        </ul>
      </div>
      {image ? (
        <img src={image} alt={imageAlt ?? `${titre} — ${site.nomEntreprise}`} class="aspect-[4/3] w-full object-cover rounded shadow-card" width="800" height="600" loading="lazy" />
      ) : (
        <div class="aspect-[4/3] bg-anthracite-100 rounded flex flex-col items-center justify-center text-anthracite-400 gap-2">
          <Icon name="image" class="w-8 h-8" />
          <span class="text-sm">Photo à venir</span>
        </div>
      )}
    </div>
  </section>

  <section class="section bg-white">
    <div class="container-page">
      <h2 class="section-title text-center mb-12">Notre méthode en 4 étapes</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {etapes.map((e) => (
          <div class="text-center">
            <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-chantier-500 text-anthracite-800 flex items-center justify-center text-xl font-bold">
              {e.n}
            </div>
            <h3 class="font-semibold mb-2">{e.titre}</h3>
            <p class="text-sm text-anthracite-500 leading-relaxed">{e.texte}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-page max-w-3xl">
      <h2 class="section-title text-center mb-10">Questions fréquentes</h2>
      <div class="space-y-3">
        {faq.map((item) => (
          <details class="card cursor-pointer group">
            <summary class="font-semibold text-anthracite-800 list-none flex justify-between items-center">
              {item.q}
              <span class="text-chantier-500 group-open:rotate-45 transition-transform text-2xl">+</span>
            </summary>
            <p class="mt-3 text-anthracite-600 leading-relaxed">{item.r}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-anthracite-800 text-white text-center">
    <div class="container-page max-w-2xl">
      <h2 class="text-3xl font-display font-semibold mb-4">Votre projet mérite un devis sur mesure</h2>
      <p class="text-anthracite-200 mb-8">Décrivez-nous votre projet, nous vous recontactons rapidement.</p>
      <a href="/contact" class="btn-primary">Demander un devis gratuit</a>
    </div>
  </section>
</BaseLayout>
