---
import { site, services, nav } from '../config/site';
import Icon from './Icon.astro';
const year = new Date().getFullYear();
---

<footer class="bg-anthracite-800 text-anthracite-200 mt-20">
  <div class="container-page py-12 grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
    <div>
      <img src="/img/logo-sombre.jpg" alt={`Logo ${site.nomEntreprise}`} class="h-20 w-auto mb-4 rounded" width="80" height="80" />
      <p class="text-sm text-anthracite-300 leading-relaxed">
        {site.baseline} Intervention {site.zone}.
      </p>
      <p class="text-sm text-chantier-400 italic mt-3">{site.slogan}</p>
    </div>

    <div>
      <p class="text-white font-semibold mb-3">Nos services</p>
      <ul class="space-y-2 text-sm">
        {services.map((s) => (
          <li>
            <a href={`/services/${s.slug}`} class="hover:text-chantier-400 transition-colors">
              {s.titreCourt}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div>
      <p class="text-white font-semibold mb-3">Liens utiles</p>
      <ul class="space-y-2 text-sm">
        {nav.slice(1).map((item) => (
          <li>
            <a href={item.href} class="hover:text-chantier-400 transition-colors">{item.label}</a>
          </li>
        ))}
        <li><a href="/mentions-legales" class="hover:text-chantier-400 transition-colors">Mentions légales</a></li>
        <li><a href="/politique-confidentialite" class="hover:text-chantier-400 transition-colors">Confidentialité</a></li>
      </ul>
    </div>

    <div>
      <p class="text-white font-semibold mb-3">Contact</p>
      <ul class="space-y-2 text-sm">
        <li>
          <a href={`tel:${site.telephoneRaw}`} class="flex items-center gap-2 hover:text-chantier-400 transition-colors">
            <Icon name="phone" class="w-4 h-4 shrink-0 text-chantier-400" />{site.telephone}
          </a>
        </li>
        <li>
          <a href={`tel:${site.telephoneTertiaire.replace(/\s/g, '')}`} class="flex items-center gap-2 hover:text-chantier-400 transition-colors">
            <Icon name="phone" class="w-4 h-4 shrink-0 text-chantier-400" />{site.telephoneTertiaire}
          </a>
        </li>
        <li>
          <a href={`tel:${site.telephoneSecondaire.replace(/\s/g, '')}`} class="flex items-center gap-2 hover:text-chantier-400 transition-colors">
            <Icon name="phone" class="w-4 h-4 shrink-0 text-chantier-400" />{site.telephoneSecondaire} <span class="text-anthracite-400 text-xs">(France)</span>
          </a>
        </li>
        <li>
          <a href={`mailto:${site.email}`} class="flex items-center gap-2 hover:text-chantier-400 transition-colors break-all">
            <Icon name="mail" class="w-4 h-4 shrink-0 text-chantier-400" />{site.email}
          </a>
        </li>
        <li>
          <a href={`mailto:${site.emailSecondaire}`} class="flex items-center gap-2 hover:text-chantier-400 transition-colors break-all">
            <Icon name="mail" class="w-4 h-4 shrink-0 text-chantier-400" />{site.emailSecondaire}
          </a>
        </li>
        <li class="flex items-center gap-2 text-anthracite-300"><Icon name="pin" class="w-4 h-4 shrink-0 text-chantier-400" />{site.adresse.ville}, {site.pays}</li>
        <li class="flex items-center gap-2 text-anthracite-300"><Icon name="clock" class="w-4 h-4 shrink-0 text-chantier-400" />{site.horaires}</li>
      </ul>
    </div>
  </div>

  <div class="border-t border-anthracite-700">
    <div class="container-page py-5 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-anthracite-400">
      <p>© {year} {site.nomEntreprise} — Tous droits réservés</p>
      <p>Entreprise de {site.metier} — intervention {site.zone}</p>
    </div>
  </div>
</footer>

<a
  href={`https://wa.me/${site.whatsapp.replace(/[^0-9]/g, '')}`}
  target="_blank"
  rel="noopener"
  class="fixed bottom-6 right-6 z-40 bg-green-500 hover:bg-green-600 text-white rounded-full p-4 shadow-elevated transition-colors"
  aria-label="Contacter sur WhatsApp"
>
  <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488"/>
  </svg>
</a>
