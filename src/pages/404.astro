---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page introuvable" noindex>
  <section class="section min-h-[60vh] flex items-center">
    <div class="container-page max-w-xl text-center">
      <p class="font-display text-7xl text-chantier-500 font-bold mb-4">404</p>
      <h1 class="text-3xl font-display font-semibold mb-3">Page introuvable</h1>
      <p class="text-anthracite-500 mb-8">
        La page que vous cherchez n'existe pas ou a été déplacée.
      </p>
      <a href="/" class="btn-primary">Retour à l'accueil</a>
    </div>
  </section>
</BaseLayout>
